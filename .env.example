# Copy to .env.local for local overrides. Do NOT commit .env or .env.local.
# Placeholders only — never put real secrets in frontend code or in this repo.

# Frontend: base URL for the iisauhwallet backend (Plaid sandbox). Only used when running app locally with backend.
# Example: http://localhost:3001
VITE_API_BASE_URL=

# Backend only (server/.env) — Plaid credentials must live on backend. Never store in frontend or in Git.
# Get sandbox keys from https://dashboard.plaid.com/developers/keys
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
