# Copy to .env.local for local overrides. Do NOT commit .env or .env.local.
# These are placeholders for future backend-based integration only.
# Never put real secrets in frontend code or in this repo.

# Base URL for a future backend API (e.g. your own server that talks to Plaid).
VITE_API_BASE_URL=

# Plaid credentials must live on a backend only. Never store in frontend or in Git.
# This repo does not implement Plaid; when you do, use a backend server.
PLAID_CLIENT_ID=YOUR_BACKEND_ONLY_NOT_FRONTEND
PLAID_SECRET=NEVER_STORE_IN_FRONTEND
